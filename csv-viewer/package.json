{
  "name": "csv-viewer",
  "version": "1.0.4",
  "publisher": "dotdir",
  "displayName": "CSV Viewer",
  "description": "View CSV files for .dir",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "viewers": [
      {
        "id": "csv-viewer",
        "label": "CSV Viewer",
        "patterns": [
          "*.csv"
        ],
        "entry": "dist/viewer.cjs",
        "priority": 10
      }
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "esbuild": "^0.27.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
