{
  "name": "csv-viewer",
  "version": "1.0.10",
  "publisher": "dotdir",
  "displayName": "CSV Viewer",
  "description": "View CSV files for .dir",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "viewers": [
      {
        "id": "csv-viewer",
        "label": "CSV Viewer",
        "patterns": [
          "*.csv"
        ],
        "entry": "dist/viewer.cjs",
        "priority": 10
      }
    ]
  },
  "dependencies": {
    "@dotdirfm/extension-api": "catalog:"
  },
  "devDependencies": {
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
