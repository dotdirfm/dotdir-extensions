{
  "name": "dsstore-viewer",
  "version": "1.0.2",
  "publisher": "dotdir",
  "displayName": ".DS_Store Viewer",
  "description": "View macOS .DS_Store file metadata",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "viewers": [
      {
        "id": "dsstore-viewer",
        "label": ".DS_Store Viewer",
        "patterns": [
          ".DS_Store"
        ],
        "entry": "dist/viewer.cjs",
        "priority": 10
      }
    ]
  },
  "dependencies": {
    "@dotdirfm/extension-api": "catalog:"
  },
  "devDependencies": {
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
