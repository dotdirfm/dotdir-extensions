{
  "name": "file-viewer",
  "version": "1.0.5",
  "publisher": "faraday",
  "displayName": "File Viewer",
  "description": "View file contents (text/binary) in Faraday",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "viewers": [
      {
        "id": "file-viewer",
        "label": "File Viewer",
        "patterns": [
          "*",
          "*.*"
        ],
        "entry": "dist/viewer.cjs",
        "priority": 0
      }
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "esbuild": "^0.27.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
