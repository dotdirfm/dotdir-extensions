{
  "name": "font-viewer",
  "version": "1.0.2",
  "publisher": "dotdir",
  "displayName": "Font Viewer",
  "description": "Preview font files for .dir",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "viewers": [
      {
        "id": "font-viewer",
        "label": "Font Viewer",
        "patterns": [
          "*.ttf",
          "*.otf",
          "*.woff",
          "*.woff2",
          "*.ttc",
          "*.otc"
        ],
        "entry": "dist/viewer.cjs",
        "priority": 20
      }
    ]
  },
  "dependencies": {
    "opentype.js": "^1.3.4",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@types/opentype.js": "^1.3.8",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "esbuild": "^0.27.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
