{
  "name": "image-viewer",
  "version": "1.1.4",
  "publisher": "dotdir",
  "displayName": "Image & Video Viewer",
  "description": "View images and video files for .dir",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "viewers": [
      {
        "id": "image-viewer",
        "label": "Image/Video Viewer",
        "patterns": [
          "*.png",
          "*.jpg",
          "*.jpeg",
          "*.gif",
          "*.bmp",
          "*.webp",
          "*.ico",
          "*.svg",
          "*.avif",
          "*.tiff",
          "*.tif",
          "*.mp4",
          "*.webm",
          "*.ogv",
          "*.ogg",
          "*.mov",
          "*.m4v"
        ],
        "entry": "dist/viewer.cjs",
        "priority": 10
      }
    ],
    "commands": [
      {
        "command": "imageViewer.navigatePrev",
        "title": "Image Viewer: Previous"
      },
      {
        "command": "imageViewer.navigateNext",
        "title": "Image Viewer: Next"
      }
    ],
    "keybindings": [
      {
        "command": "imageViewer.navigatePrev",
        "key": "left",
        "when": "focusViewer"
      },
      {
        "command": "imageViewer.navigateNext",
        "key": "right",
        "when": "focusViewer"
      }
    ]
  },
  "dependencies": {
    "mp4box": "catalog:"
  },
  "devDependencies": {
    "@dotdirfm/extension-api": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
