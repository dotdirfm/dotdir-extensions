{
  "name": "monaco-editor",
  "version": "1.0.5",
  "publisher": "dotdir",
  "displayName": "Monaco Editor",
  "description": "Monaco-based code editor for .dir with syntax highlighting",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "editors": [
      {
        "id": "monaco",
        "label": "Monaco Editor",
        "patterns": [
          "*.*"
        ],
        "entry": "dist/editor.cjs",
        "priority": 0
      }
    ],
    "languages": [
      {
        "id": "plaintext",
        "aliases": [
          "Plain Text"
        ],
        "extensions": [
          ".txt"
        ]
      },
      {
        "id": "json",
        "aliases": [
          "JSON"
        ],
        "extensions": [
          ".json",
          ".jsonc"
        ]
      },
      {
        "id": "typescript",
        "aliases": [
          "TypeScript"
        ],
        "extensions": [
          ".ts",
          ".mts",
          ".cts"
        ]
      },
      {
        "id": "javascript",
        "aliases": [
          "JavaScript"
        ],
        "extensions": [
          ".js",
          ".mjs",
          ".cjs"
        ]
      },
      {
        "id": "markdown",
        "aliases": [
          "Markdown"
        ],
        "extensions": [
          ".md",
          ".mdx"
        ]
      },
      {
        "id": "html",
        "aliases": [
          "HTML"
        ],
        "extensions": [
          ".html",
          ".htm"
        ]
      },
      {
        "id": "css",
        "aliases": [
          "CSS"
        ],
        "extensions": [
          ".css"
        ]
      },
      {
        "id": "yaml",
        "aliases": [
          "YAML"
        ],
        "extensions": [
          ".yml",
          ".yaml"
        ]
      },
      {
        "id": "xml",
        "aliases": [
          "XML"
        ],
        "extensions": [
          ".xml"
        ]
      },
      {
        "id": "shellscript",
        "aliases": [
          "Shell Script"
        ],
        "extensions": [
          ".sh",
          ".bash",
          ".zsh"
        ]
      }
    ],
    "grammars": []
  },
  "dependencies": {
    "monaco-editor": "catalog:",
    "vscode-oniguruma": "catalog:",
    "vscode-textmate": "catalog:"
  },
  "devDependencies": {
    "@dotdirfm/extension-api": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
