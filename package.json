{
  "name": "dotdir-extensions",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "build:monaco": "pnpm --filter monaco-editor run build",
    "build:image-viewer": "pnpm --filter image-viewer run build",
    "build:file-viewer": "pnpm --filter file-viewer run build",
    "dev": "pnpm -r run dev",
    "zip": "node scripts/pack.mjs",
    "publish:dotdir": "node scripts/publish.mjs",
    "release:dotdir": "pnpm build && pnpm zip && pnpm publish:dotdir",
    "ver:patch": "pnpm -r exec pnpm version patch"
  },
  "devDependencies": {
    "archiver": "catalog:"
  }
}
