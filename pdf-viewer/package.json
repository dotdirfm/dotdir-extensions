{
  "name": "pdf-viewer",
  "version": "1.0.2",
  "publisher": "faraday",
  "displayName": "PDF Viewer",
  "description": "View PDF files in Faraday",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "viewers": [
      {
        "id": "pdf-viewer",
        "label": "PDF Viewer",
        "patterns": [
          "*.pdf"
        ],
        "entry": "dist/viewer.iife.js",
        "priority": 10
      }
    ]
  },
  "dependencies": {},
  "devDependencies": {
    "esbuild": "^0.27.0",
    "typescript": "~5.9.3",
    "vite": "^8.0.0"
  }
}
