{
  "name": "sqlite-editor",
  "version": "1.0.7",
  "publisher": "dotdir",
  "displayName": "SQLite Editor",
  "description": "Browse and query SQLite databases for .dir",
  "type": "module",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch"
  },
  "contributes": {
    "editors": [
      {
        "id": "sqlite-editor",
        "label": "SQLite Editor",
        "patterns": [
          "*.sqlite",
          "*.sqlite3",
          "*.db",
          "*.db3"
        ],
        "entry": "dist/editor.cjs",
        "priority": 50
      }
    ]
  },
  "dependencies": {
    "react": "catalog:",
    "react-dom": "catalog:",
    "sql.js": "catalog:"
  },
  "devDependencies": {
    "@dotdirfm/extension-api": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/sql.js": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "esbuild": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
